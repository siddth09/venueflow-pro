{
  "name": "venueflow-pro",
  "version": "1.0.0",
  "description": "AI-powered stadium companion — real-time crowd navigation, smart recommendations, and in-seat food ordering.",
  "scripts": {
    "build": "postcss style.css -r && node build.js && npm test",
    "test": "jest --coverage --coverageDirectory=coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/ --ext .js",
    "serve": "npx serve . -p 8080"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.10",
    "postcss-cli": "^11.0.1",
    "postcss-preset-env": "^11.2.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/engine/simulator.cjs"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 30,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  },
  "keywords": [
    "stadium",
    "ai",
    "assistant",
    "gemini",
    "google-cloud",
    "crowd-management",
    "firebase",
    "venue",
    "smart-stadium",
    "real-time"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/siddth09/venueflow-pro"
  }
}
