{
  "name": "venueflow-pro",
  "version": "1.0.0",
  "description": "AI-powered stadium companion — real-time crowd navigation, smart recommendations, and in-seat food ordering.",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "node app.js",
    "test": "jest --coverage --coverageDirectory=coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/ app.js --ext .js",
    "serve": "npx serve . -p 8080"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": [
      "src/engine/simulator.cjs",
      "app.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 30,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  },
  "keywords": [
    "stadium", "ai", "assistant", "gemini", "google-cloud", "crowd-management",
    "firebase", "venue", "smart-stadium", "real-time"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/siddth09/venueflow-pro"
  }
}
